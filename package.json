{
  "name": "emotion-hero",
  "version": "1.0.0",
  "description": "Real-time emotional visualization system",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "build": "npm run build -w shared && npm run build -w backend && npm run build -w frontend",
    "dev": "npm run dev --workspaces --parallel",
    "clean": "npm run clean --workspaces",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}